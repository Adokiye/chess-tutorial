		<style type="text/css" id="wp-custom-css">
			/* =========================
   GLOBAL CF7 FORM SYSTEM
========================= */

.wpcf7 form {
  max-width: 800px;
  margin: 40px auto;
  padding: 30px;
  background: #ffffff;
  border-radius: 14px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.08);
  font-family: 'Inter', sans-serif;
}

/* =========================
   HEADERS
========================= */

.wpcf7 .form-header h2 {
  color: #F99F23;
  font-size: 26px;
  margin-bottom: 10px;
}

.wpcf7 .form-header p {
  color: #666;
  font-size: 14px;
}

/* =========================
   SECTIONS
========================= */

.wpcf7 .form-section {
  margin-top: 30px;
}

.wpcf7 .form-section h3 {
  font-size: 17px;
  margin-bottom: 12px;
  color: #222;
  border-left: 4px solid #F99F23;
  padding-left: 10px;
}

/* =========================
   LABELS
========================= */

.wpcf7 label {
  display: block;
  margin-bottom: 14px;
  color: #333;
  font-weight: 500;
}

/* =========================
   INPUTS
========================= */

.wpcf7 input,
.wpcf7 select,
.wpcf7 textarea {
  width: 100%;
  padding: 12px;
  margin-top: 6px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 14px;
  transition: 0.3s ease;
  background: #fff;
}

/* Focus State */
.wpcf7 input:focus,
.wpcf7 select:focus,
.wpcf7 textarea:focus {
  border-color: #F99F23;
  box-shadow: 0 0 0 3px rgba(249,159,35,0.2);
  outline: none;
}

/* Textarea */
.wpcf7 textarea {
  min-height: 120px;
}

/* =========================
   RADIO BUTTONS
========================= */

.wpcf7 .radio-group .wpcf7-list-item {
  display: inline-flex;
  align-items: center;
  margin-right: 20px;
}

.wpcf7 .radio-group input {
  width: auto;
  margin-right: 6px;
}

/* =========================
   CHECKBOX GROUP (MULTIPLE)
========================= */

.wpcf7 .checkbox-group .wpcf7-list-item {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.wpcf7 .checkbox-group input {
  width: auto;
  margin-right: 8px;
}

/* =========================
   SINGLE CHECKBOX (TERMS)
========================= */

.wpcf7 .checkbox {
  display: block;
  margin-bottom: 12px;
  background: #fafafa;
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid #eee;
}

.wpcf7 .checkbox .wpcf7-list-item {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0;
}

.wpcf7 .checkbox input {
  width: auto;
  margin: 0;
}

/* =========================
   FILE INPUT
========================= */

.wpcf7 input[type="file"] {
  border: none;
}

/* =========================
   SUBMIT BUTTON
========================= */

.wpcf7 input[type="submit"] {
  width: 100%;
  background: #F99F23;
  color: #fff;
  padding: 14px;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  cursor: pointer;
  transition: 0.3s ease;
}

.wpcf7 input[type="submit"]:hover {
  background: #e68c0f;
  transform: translateY(-2px);
}

/* =========================
   FOOTER TEXT
========================= */

.wpcf7 .form-footer {
  margin-top: 20px;
  font-size: 14px;
  color: #444;
}

/* =========================
   FORM GROUP (OPTIONAL)
========================= */

.wpcf7 .form-group {
  margin-bottom: 15px;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width: 600px) {
  .wpcf7 form {
    padding: 20px;
  }

  .wpcf7 .form-header h2 {
    font-size: 20px;
  }
}		</style>
