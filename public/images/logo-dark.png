/* ---------------- */
/* Hamburger / close toggle button */
.menu-toggle {
  font-size: 30px;       /* size of icon */
  color: #ffffff;        /* white */
  cursor: pointer;
  user-select: none;
  position: relative;
  z-index: 10001;
  display: none;         /* hide by default */
  padding: 10px 20px;    /* bigger clickable area */
  background: transparent;
  transition: transform 0.3s;
}

/* Change ☰ to ✕ when checked */
#mobile-menu-toggle:checked + .menu-toggle::after {
  content: '✕';
}

/* Original hamburger content */
.menu-toggle::after {
  content: '☰';
}

/* Hide checkbox */
#mobile-menu-toggle {
  display: none;
}

/* Fullscreen menu overlay */
.mobile-menu {
  display: none;
  position: fixed;       /* cover viewport */
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #000;      /* black background */
  z-index: 10000;
  padding-top: 60px;     /* adjust for header space */
  overflow-y: auto;
  text-align: center;
}

/* Show menu when checked */
#mobile-menu-toggle:checked + .menu-toggle + .mobile-menu {
  display: block;
}

/* Menu links */
.mobile-menu a {
  display: block;
  margin: 20px auto;
  text-decoration: none;
  color: #f58220;        /* orange */
  font-size: 24px;
  font-weight: 600;
  border-bottom: 1px solid #f58220;
  width: 80%;
  padding: 12px 0;
  box-sizing: border-box;
  border-radius: 6px;
}

/* Remove last border */
.mobile-menu a:last-child {
  border-bottom: none;
}

/* Hover effect */
.mobile-menu a:hover {
  background: rgba(245, 130, 32, 0.08);
}

/* ---------------- */
/* Responsive: show only on mobile */
@media (max-width: 767px) {
  .menu-toggle {
    display: inline-block;
  }
}

@media (min-width: 768px) {
  /* hide the mobile menu on tablet/desktop */
  .mobile-menu {
    display: none !important;
  }
}
</style>

